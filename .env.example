# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# LiveKit (defaults match `docker compose up livekit` dev mode)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── LAN testing (laptop + phone on same Wi‑Fi) ──
# Easiest: npm run dev:lan  (auto-detects your IP)
# Or set manually, e.g. if your laptop is 192.168.1.50:
# CLIENT_URL=http://192.168.1.50:5173
# LIVEKIT_URL=ws://192.168.1.50:7880
